# Required: AI Gateway API key (used by both rag-service and webapp)
OWL_AI_GATEWAY_API_KEY=your-ai-gateway-api-key

# Optional: Override defaults
# OWL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
# OWL_LLM_MODEL=openai/gpt-4o-mini
# OWL_VISION_MODEL=openai/gpt-4o
# OWL_EMBED_MODEL=openai/text-embedding-3-small
# OWL_EMBED_DIMENSION=1536

# Optional: Webapp AI key (defaults to OWL_AI_GATEWAY_API_KEY if not set)
# AI_GATEWAY_API_KEY=your-ai-gateway-api-key
